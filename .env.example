# Search engine site verification codes (issued by each webmaster console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Resend (contact form delivery, checkout confirmation, manage magic links).
# CONTACT_TO_EMAIL also receives domain non-renewal requests submitted from /manage.
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Self-service manage page (HMAC secret for 15-min magic-link tokens).
# Generate with: openssl rand -hex 32
MANAGE_TOKEN_SECRET=

# Stripe (Pricing checkout)
# Server-side secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) — set per-environment from Stripe Dashboard
STRIPE_WEBHOOK_SECRET=
# Public site URL used for Stripe success/cancel redirects (e.g. https://makepageit.com)
NEXT_PUBLIC_SITE_URL=

# Stripe Price IDs — create these Products/Prices in the Stripe Dashboard.
# - SETUP: one-time price (e.g. $299 / $449), included in initial Checkout
# - MONTHLY: recurring price (interval: month), creates the maintenance subscription
# - DOMAIN_FIRST_YEAR: one-time price ($20), included in initial Checkout for year 1
# - DOMAIN_RENEWAL: recurring yearly price ($20). After checkout completes, the
#   webhook auto-creates a separate yearly subscription with billing_cycle_anchor
#   set to 1 year out — so the customer is billed $0 today and $20/yr from year 2.
#   Customers can cancel either subscription independently via the Stripe Billing
#   Portal (linked from /manage).
STRIPE_PRICE_LITE_SETUP=
STRIPE_PRICE_LITE_MONTHLY=
STRIPE_PRICE_LITE_DOMAIN_FIRST_YEAR=
STRIPE_PRICE_LITE_DOMAIN_RENEWAL=
# Pro plan (Phase 2 — wire up after Lite is verified end-to-end)
STRIPE_PRICE_PRO_SETUP=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_DOMAIN_FIRST_YEAR=
STRIPE_PRICE_PRO_DOMAIN_RENEWAL=
